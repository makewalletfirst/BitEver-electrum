             <script>
    $(function() {
        bizx.cmp.ifConsent({ purposes: 'all' , vendors: 'narrative'}, function() {
            var current_time = (new Date()).getTime();
            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3A984f31e5-3ac4-4a05-96dc-919fe785ef24&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Flibiconv%2F&id=pagetitle%3AGNU+libiconv+-+character+set+conversions+download+%7C+SourceForge.net&id=vertical%3AOpen+Source+Software&id=product%3AGNU+libiconv+-+character+set+conversions&id=topics%3AText+Processing&id=programming_language%3AC";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
